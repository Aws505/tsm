Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/

# ── Claude Code local settings ────────────────────────────────────────────────
.claude/settings.local.json

# ── Shell / env overrides ─────────────────────────────────────────────────────
.env
.env.local
*.local.conf
